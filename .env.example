# Copy to .env and fill in real values
# Get Clerk keys from https://dashboard.clerk.com → API Keys

# Clerk
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard

# LLM
LLM_MODEL=mistral/mistral-small-latest
MISTRAL_API_KEY=

# Storage (OVH Object Storage / S3-compatible)
STORAGE_ENDPOINT=
STORAGE_BUCKET=pitchdeck
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Langfuse (auto-populated by docker-compose in dev — set these after first login at localhost:3001)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-web:3000
